{
  "version": 2,
  "installCommand": "cd blog-backend && npm install --include=dev && cd ../blog-frontend && npm install --include=dev",
  "buildCommand": "cd blog-backend && npm run build:prepare && npm run build && cd ../blog-frontend && npm run build",
  "outputDirectory": "blog-frontend/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "blog-backend/dist/**",
        "blog-backend/data/ip2region_v4.xdb",
        "blog-backend/data/sensitive_words.txt"
      ],
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/docs", "dest": "/404.html" },
    { "src": "/docs/(.*)", "dest": "/404.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
