# Database
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"
# For Vercel Postgres:
# DATABASE_URL="postgresql://user:password@host:5432/db?pgbouncer=true&connect_timeout=15"
# DATABASE_PROVIDER=postgresql

JWT_SECRET="your-jwt-secret-change-in-production"
PORT=3000

LLM_BASE_URL="http://your-llm-server:8080"
LLM_API_KEY="your-key"
LLM_MODEL="deepseek-v4-pro"

# 图床（图片上传）：picgo.net / 任意 Chevereto 兼容图床
# 线上必须配置，否则上传接口返回“图床未配置”
IMG_HOST_API_KEY="chv_xxxxxxxx"
# 可选，默认 https://www.picgo.net/api/1/upload
IMG_HOST_ENDPOINT="https://www.picgo.net/api/1/upload"
